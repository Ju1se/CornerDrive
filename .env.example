# FLPG Environment Configuration
# Copy this file to .env and fill in your values

# ============ NETWORK INFRASTRUCTURE ============
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
GANACHE_URL=http://localhost:8545
POLICY_AGENT_URL=http://localhost:8083
L1_URL=http://localhost:8081
L4_URL=http://localhost:8082

# ============ L1: LINEAR DEFENSE ============
L1_HOST=127.0.0.1
L1_PORT=8081
L1_SUSPECT_THRESHOLD=0.3
L1_GEOMETRIC_MEDIAN_MAX_ITER=100
L1_GEOMETRIC_MEDIAN_EPS=1e-6
L1_BATCH_SIZE=10
L1_BATCH_TIMEOUT=5.0
L1_MAX_GRADIENT_DIM=50000
L1_MAX_GRADIENT_ABS=1000000

# ============ L2: DUAL-PURPOSE AUDIT ============
L2_FRAUD_THRESHOLD=0.05
L2_RARITY_THRESHOLD=-0.03
L2_LEARNING_RATE=0.01
L2_AUDIT_QUEUE=l2_audit_queue

# ============ L3: GATEKEEPER ============
L3_DRIFT_THRESHOLD=0.05
L3_GOLDEN_DATASET_PATH=data/validation/golden

# ============ L4: SETTLEMENT ============
L4_DASHBOARD_HOST=127.0.0.1
L4_DASHBOARD_PORT=8082
L4_CONTRACT_ADDRESS=
L4_ORACLE_PRIVATE_KEY=

# ============ SBT CREDIT SYSTEM ============
SBT_HONEST_REWARD=1
SBT_RARITY_REWARD=10
SBT_FRAUD_PENALTY=-50

# ============ POLICY AGENT ============
POLICY_AGENT_HOST=0.0.0.0
POLICY_AGENT_PORT=8083

# ============ GLM LLM ASSISTANT (OPTIONAL) ============
# IMPORTANT: Regenerate this key before production use
# Never commit real API keys to source control
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7
GLM_TIMEOUT=45
GLM_FAILURE_BACKOFF_SECONDS=300
GLM_MAX_TOKENS=1200
GLM_RETRY_MAX_TOKENS=1800
GLM_THINKING=disabled

# LLM Operating Mode:
# - hybrid: Use rule engine by default, LLM only for complex scenarios (recommended)
# - always: Use LLM for every proposal (expensive, thorough)
# - rule_only: Never use LLM, rule engine only (fastest)
GLM_MODE=hybrid

# ============ POLICY BLOCKCHAIN COMMITMENT (OPTIONAL) ============
POLICY_CHAIN_COMMIT_ENABLED=false
POLICY_REGISTRY_ADDRESS=
POLICY_ORACLE_PRIVATE_KEY=

# ============ SECURITY ============
# Replace before exposing services outside localhost.
VALID_API_KEYS=change-me-local-dev-key
DEMO_API_KEY=change-me-local-dev-key
RATE_LIMIT=100/minute
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
L1_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
L4_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VITE_API_KEY=change-me-local-dev-key
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin

# ============ LOGGING ============
LOG_LEVEL=INFO
